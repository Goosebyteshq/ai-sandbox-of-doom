{
  "version": 1,
  "provider": "codex",
  "checkpoint_every_actions": 4,
  "adversarial_interval_minutes": 10,
  "fast_tests": [
    "go test ./..."
  ],
  "integration_tests": [
    "make test-integration"
  ],
  "risky_paths": [
    ".github/",
    "infra/",
    "deploy/",
    "docker-compose.yml",
    "Dockerfile"
  ],
  "sensitive_paths": [
    "/etc/",
    "/root/",
    ".ssh/",
    ".aws/",
    ".gnupg/"
  ],
  "blocked_command_prefixes": [
    "rm -rf /",
    "mkfs",
    "dd if=",
    "shutdown",
    "reboot"
  ],
  "justify_command_prefixes": [
    "git push --force",
    "git reset --hard",
    "docker system prune",
    "docker volume rm"
  ],
  "generated_file_patterns": [
    "dist/",
    "vendor/",
    "*.generated.*"
  ]
}
