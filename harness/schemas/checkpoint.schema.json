{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doombox.dev/schemas/checkpoint.schema.json",
  "title": "Doombox Harness Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "timestamp",
    "agent",
    "current_goal",
    "files_changed",
    "out_of_scope_files",
    "next_step_to_scope",
    "non_obvious_file_justifications"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "string",
      "enum": [
        "codex",
        "gemini",
        "cloud",
        "unknown"
      ]
    },
    "current_goal": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "out_of_scope_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_step_to_scope": {
      "type": "string",
      "minLength": 1
    },
    "non_obvious_file_justifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "file",
          "why"
        ],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cmd",
          "result"
        ],
        "properties": {
          "cmd": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip"
            ]
          }
        }
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
